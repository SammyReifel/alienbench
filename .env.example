# alienbench provider keys.
#
# You only need keys for providers whose models you actually run. The default
# roster (DEFAULT_MODELS in src/providers.ts) requires NVIDIA_API_KEY.
#
# Get keys:
#   NVIDIA Build  — https://build.nvidia.com         (free tier, OpenAI-compatible)
#   OpenAI        — https://platform.openai.com
#   OpenRouter    — https://openrouter.ai            (free models with `:free` suffix)
#   Groq          — https://console.groq.com
#   Cerebras      — https://cloud.cerebras.ai
#   Teracast      — https://teracast.net             (moonshot, zhipu, nvidia/nemotron)

# ---------- default provider ----------
NVIDIA_API_KEY=

# ---------- additional providers (uncomment + fill if needed) ----------
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# TERACAST_API_KEY=

# ---------- generic OpenAI-compatible endpoint override ----------
# Use these to point at any other OpenAI-compatible gateway (e.g. self-hosted
# vLLM). PROVIDER_API_KEY takes precedence over NVIDIA_API_KEY when set.
# PROVIDER_BASE_URL=https://integrate.api.nvidia.com/v1
# PROVIDER_API_KEY=

# ---------- optional, dev-only: local Codex/ChatGPT OAuth proxy ----------
# Used by `codex-oauth/*` model ids. Requires running a local proxy that
# authenticates with the Codex OAuth cache. Off by default; ignore unless
# you've set one up.
# CHATGPT_OAUTH_BASE_URL=http://127.0.0.1:10531/v1
# CHATGPT_OAUTH_API_KEY=codex-oauth
